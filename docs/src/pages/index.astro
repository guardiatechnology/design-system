---
/**
 * Port fiel do wip/preview/home.html — shell de navegação do DS:
 * topbar com busca, sidebar com catálogo completo, welcome state, iframe
 * para carregar cada página de fundamentos/componentes.
 *
 * As páginas referenciadas vivem em docs/public/preview/<slug>.html
 * (cópia 1:1 de wip/preview/*.html). Componentes ainda não migrados
 * apontam para um stub com aviso.
 */
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const logoUrl = `${base}/assets/logo/guardia-logotipo-purple.svg`;
const colorsCssUrl = `${base}/colors_and_type.css`;
const previewUrl = (file: string) => `${base}/preview/${file}`;
const storybookUrl = import.meta.env.DEV
  ? "http://localhost:6006/"
  : "https://69e15f3b0534f646ac88774b-cpmytvatdp.chromatic.com/";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <title>Guardia · Design System</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${base}/assets/logo/guardia-logo-purple-rounded.svg`} />
    <link rel="stylesheet" href={colorsCssUrl} />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; height: 100%; }
      body {
        font-family: var(--font-sans);
        color: var(--fg);
        background: var(--bg);
        display: grid;
        grid-template-columns: 288px 1fr;
        grid-template-rows: 56px 1fr;
        grid-template-areas:
          "top top"
          "nav main";
        height: 100vh;
        overflow: hidden;
      }

      /* ============ TOPBAR ============ */
      .top {
        grid-area: top;
        display: flex; align-items: center; gap: 16px;
        padding: 0 20px 0 24px;
        border-bottom: 1px solid var(--border);
        background: #fff;
        z-index: 10;
      }
      .top-brand { display: flex; align-items: center; gap: 12px; }
      .top-brand img { height: 40px; width: auto; display: block; }
      .top-brand .dot {
        width: 4px; height: 4px; border-radius: 50%;
        background: var(--gray-300); margin: 0 8px;
      }
      .top-brand .ds-label {
        font-size: 12px; font-weight: 500;
        color: var(--gray-500); letter-spacing: -0.005em;
      }
      .top-brand .ver {
        font-family: var(--font-mono); font-size: 10px;
        color: var(--gray-500); background: var(--violet-100);
        padding: 2px 6px; border-radius: 4px; margin-left: 8px;
      }
      .top-search {
        flex: 1; max-width: 520px; margin: 0 auto;
        position: relative;
      }
      .top-search input {
        width: 100%; height: 32px;
        background: var(--gray-50);
        border: 1px solid transparent;
        border-radius: var(--radius-md);
        padding: 0 34px 0 32px;
        font: inherit; font-size: 13px; color: var(--fg);
        outline: none; transition: background .12s, border-color .12s;
      }
      .top-search input:focus {
        background: #fff;
        border-color: var(--violet-300);
        box-shadow: 0 0 0 3px rgba(113, 64, 171, 0.12);
      }
      .top-search::before {
        content: ""; position: absolute;
        top: 9px; left: 10px;
        width: 14px; height: 14px;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%23A09AA6' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='8'/><path d='m21 21-4.3-4.3'/></svg>");
        background-repeat: no-repeat;
      }
      .top-search kbd {
        position: absolute; top: 6px; right: 8px;
        font-family: var(--font-mono); font-size: 10px;
        color: var(--gray-500);
        background: #fff; border: 1px solid var(--border);
        border-radius: 4px; padding: 2px 5px;
        line-height: 1;
      }
      .top-right { display: flex; align-items: center; gap: 14px; }
      .top-link {
        font-size: 12px; color: var(--gray-700);
        text-decoration: none; padding: 4px 8px; border-radius: 4px;
      }
      .top-link:hover { background: var(--gray-50); color: var(--violet-500); }
      .search-meta {
        position: absolute; top: 9px; right: 36px;
        font-size: 10px; color: var(--gray-500);
        font-family: var(--font-mono);
        pointer-events: none;
      }

      /* ============ SIDEBAR ============ */
      .nav {
        grid-area: nav;
        background: #FDFCFE;
        border-right: 1px solid var(--border);
        overflow-y: auto;
        padding: 20px 14px 40px;
      }
      .nav-group { margin-bottom: 18px; }
      .nav-group-sub { margin-bottom: 12px; padding-left: 8px; position: relative; }
      .nav-group-sub::before {
        content: "";
        position: absolute;
        left: 0; top: 22px; bottom: 4px;
        width: 1px;
        background: var(--violet-100);
      }
      .nav-parent {
        margin: 6px 0 10px;
        padding: 10px 10px 6px;
        border-top: 1px solid var(--border);
      }
      .nav-parent:first-child { border-top: 0; padding-top: 4px; }
      .nav-parent-title {
        font-size: 11px; font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--violet-500);
        display: flex; align-items: center; gap: 8px;
      }
      .nav-parent-title::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--violet-100);
      }
      .nav-group-title {
        display: flex; align-items: center; gap: 8px;
        font-size: 10px; font-weight: 600;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--gray-500);
        padding: 0 10px 6px;
      }
      .nav-group-count {
        font-family: var(--font-mono); font-size: 9px;
        color: var(--gray-500); background: var(--gray-50);
        padding: 1px 5px; border-radius: 3px;
        letter-spacing: 0;
      }
      .nav-item {
        display: flex; align-items: center; gap: 10px;
        padding: 6px 10px;
        font-size: 13px; color: var(--gray-700);
        text-decoration: none;
        border-radius: var(--radius-sm);
        cursor: pointer;
        line-height: 1.3;
        border: 1px solid transparent;
      }
      .nav-item:hover { background: var(--violet-100); color: var(--violet-500); }
      .nav-item.active {
        background: var(--violet-100);
        color: var(--violet-500);
        font-weight: 500;
      }
      .nav-item .ni-glyph {
        font-family: var(--font-mono); font-size: 9px;
        color: var(--gray-500);
        background: #fff; border: 1px solid var(--border);
        border-radius: 3px; padding: 1px 4px;
        min-width: 24px; text-align: center;
        letter-spacing: -0.02em;
      }
      .nav-item.active .ni-glyph {
        background: var(--violet-500); color: #fff; border-color: var(--violet-500);
      }
      .nav-item .ni-label { flex: 1; }
      .nav-empty {
        padding: 16px 12px;
        font-size: 12px; color: var(--gray-500);
        text-align: center;
        display: none;
      }
      .nav-empty.visible { display: block; }

      .nav-item.hide { display: none; }
      .nav-group.hide-all { display: none; }
      .nav-parent.hide-all { display: none; }

      /* ============ MAIN ============ */
      main {
        grid-area: main;
        overflow: hidden;
        position: relative;
        background: #fff;
      }
      main iframe {
        width: 100%; height: 100%;
        border: 0; display: block;
        background: #fff;
      }

      .welcome {
        height: 100%; overflow-y: auto;
        padding: 48px 56px;
      }
      .welcome-hdr {
        display: flex; align-items: baseline; gap: 14px;
        margin-bottom: 8px;
      }
      .welcome-eyebrow {
        font-size: 10px; font-weight: 600;
        letter-spacing: 0.14em; text-transform: uppercase;
        color: var(--gray-500);
      }
      .welcome h1 {
        margin: 4px 0 10px;
        font-size: 36px; font-weight: 700; letter-spacing: -0.025em;
        color: var(--violet-500);
      }
      .welcome p.lede {
        font-size: 15px; color: var(--gray-700);
        max-width: 680px; line-height: 1.6;
        margin: 0 0 32px;
      }
      .welcome-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 36px;
        max-width: 780px;
      }
      .stat {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 14px 16px;
      }
      .stat b {
        display: block;
        font-size: 28px; font-weight: 700; letter-spacing: -0.02em;
        color: var(--violet-500);
        font-family: var(--font-mono); font-variant-numeric: tabular-nums;
      }
      .stat span {
        font-size: 11px; color: var(--gray-500);
        text-transform: uppercase; letter-spacing: 0.08em;
        font-weight: 500;
      }
      .welcome-section { margin-top: 32px; }
      .welcome-section-hdr {
        display: flex; align-items: baseline; gap: 10px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 8px; margin-bottom: 16px;
      }
      .welcome-section-hdr h2 {
        margin: 0; font-size: 14px; font-weight: 600;
        color: var(--fg); letter-spacing: -0.005em;
      }
      .welcome-section-hdr small {
        font-size: 11px; color: var(--gray-500);
      }
      .quick-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 10px;
      }
      .quick-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 14px 16px;
        display: flex; flex-direction: column; gap: 6px;
        cursor: pointer;
        transition: border-color .12s, transform .12s;
        text-align: left;
        font: inherit;
        color: inherit;
      }
      .quick-card:hover {
        border-color: var(--violet-300);
        transform: translateY(-1px);
      }
      .quick-card .qc-eyebrow {
        font-size: 9px; font-weight: 600;
        letter-spacing: 0.1em; text-transform: uppercase;
        color: var(--violet-500);
      }
      .quick-card .qc-title {
        font-size: 14px; font-weight: 600;
        color: var(--fg); letter-spacing: -0.01em;
      }
      .quick-card .qc-desc {
        font-size: 12px; color: var(--gray-700);
        line-height: 1.45;
      }

      /* Stub quando componente ainda não foi migrado */
      .stub-pending {
        height: 100%; display: grid; place-items: center;
        padding: 40px; text-align: center;
        background: var(--gray-50);
      }
      .stub-pending h2 {
        margin: 0 0 8px; color: var(--violet-500);
        font-size: 20px; font-weight: 600;
      }
      .stub-pending p {
        margin: 0; color: var(--gray-700); font-size: 14px;
        max-width: 420px; line-height: 1.5;
      }

      /* Scrollbars */
      .nav::-webkit-scrollbar { width: 6px; }
      .nav::-webkit-scrollbar-track { background: transparent; }
      .nav::-webkit-scrollbar-thumb {
        background: var(--gray-100); border-radius: 3px;
      }
      .nav::-webkit-scrollbar-thumb:hover { background: var(--gray-300); }
    </style>
  </head>
  <body>
    <!-- TOPBAR -->
    <header class="top">
      <div class="top-brand">
        <img src={logoUrl} alt="Guardia" />
        <span class="dot"></span>
        <span class="ds-label">Design System</span>
        <span class="ver">v1.0</span>
      </div>
      <div class="top-search">
        <input id="q" type="search" placeholder="Buscar componentes, fundamentos, tokens…" autocomplete="off" spellcheck="false" />
        <span class="search-meta" id="q-meta"></span>
        <kbd>/</kbd>
      </div>
      <div class="top-right">
        <a class="top-link" href="https://github.com/guardiafinance/design-system" target="_blank" rel="noreferrer">GitHub</a>
        <a class="top-link" href="https://www.chromatic.com/library?appId=69e15f3b0534f646ac88774b" target="_blank" rel="noreferrer">Chromatic</a>
        <a class="top-link" href={storybookUrl} target="_blank" rel="noreferrer">Storybook</a>
      </div>
    </header>

    <!-- SIDEBAR -->
    <aside class="nav" id="nav">
      <div class="nav-empty" id="nav-empty">Nenhum resultado</div>
    </aside>

    <!-- MAIN -->
    <main>
      <div class="welcome" id="welcome">
        <div class="welcome-hdr">
          <span class="welcome-eyebrow">DESIGN SYSTEM · v1.0</span>
        </div>
        <h1>Guardia DS</h1>
        <p class="lede">
          Sistema de design da Guardia — identidade, fundamentos visuais e um kit
          de componentes React. Navegue pela lateral, use a busca no topo (ou
          tecle <kbd style="font-family:var(--font-mono);font-size:11px;background:var(--gray-50);padding:1px 5px;border-radius:3px;border:1px solid var(--border)">/</kbd>) ou escolha um atalho abaixo.
        </p>

        <div class="welcome-stats">
          <div class="stat"><b>45</b><span>componentes</span></div>
          <div class="stat"><b>15</b><span>fundamentos</span></div>
          <div class="stat"><b>5</b><span>cores de marca</span></div>
          <div class="stat"><b>3</b><span>famílias tipográficas</span></div>
        </div>

        <section class="welcome-section">
          <div class="welcome-section-hdr">
            <h2>Começar por</h2>
            <small>atalhos curados</small>
          </div>
          <div class="quick-grid">
            <button class="quick-card" data-go="start/Primeiros passos">
              <span class="qc-eyebrow">COMEÇAR · SETUP</span>
              <span class="qc-title">Primeiros passos</span>
              <span class="qc-desc">Instale o pacote e renderize o primeiro componente em 5 minutos.</span>
            </button>
            <button class="quick-card" data-go="found/Branding">
              <span class="qc-eyebrow">FUNDAMENTOS · MARCA</span>
              <span class="qc-title">Branding</span>
              <span class="qc-desc">Tagline, personalidade, voz e os três pilares visuais.</span>
            </button>
            <button class="quick-card" data-go="found/Personas">
              <span class="qc-eyebrow">FUNDAMENTOS · PÚBLICO</span>
              <span class="qc-title">Personas</span>
              <span class="qc-desc">6 perfis que decidem sobre o mesmo problema.</span>
            </button>
            <button class="quick-card" data-go="found/AI-First Experience">
              <span class="qc-eyebrow">DIRETRIZ</span>
              <span class="qc-title">AI-First Experience</span>
              <span class="qc-desc">Agêntico por padrão — conversa + workspace ao vivo.</span>
            </button>
            <button class="quick-card" data-go="space/Todos os tokens">
              <span class="qc-eyebrow">TOKENS · CSS</span>
              <span class="qc-title">Todos os tokens</span>
              <span class="qc-desc">Cores, tipo, espaço, raios, sombras, motion — um só lugar.</span>
            </button>
            <button class="quick-card" data-go="color/Paleta base">
              <span class="qc-eyebrow">COR · BASE</span>
              <span class="qc-title">Paleta base</span>
              <span class="qc-desc">5 cores canônicas + Lighthouse + Mono.</span>
            </button>
            <button class="quick-card" data-go="type/Famílias">
              <span class="qc-eyebrow">TIPOGRAFIA</span>
              <span class="qc-title">Famílias</span>
              <span class="qc-desc">Lastica, Poppins e Roboto com papéis definidos.</span>
            </button>
            <button class="quick-card" data-go="prim/Button">
              <span class="qc-eyebrow">COMPONENTE</span>
              <span class="qc-title">Button</span>
              <span class="qc-desc">Ação principal — 6 variantes, 3 tamanhos.</span>
            </button>
            <button class="quick-card" data-go="data/DataTable">
              <span class="qc-eyebrow">COMPONENTE</span>
              <span class="qc-title">DataTable</span>
              <span class="qc-desc">Tabela com seleção, sort e row-actions.</span>
            </button>
            <button class="quick-card" data-go="data/AgentCard">
              <span class="qc-eyebrow">COMPONENTE</span>
              <span class="qc-title">AgentCard</span>
              <span class="qc-desc">Card do agente com capabilities e status.</span>
            </button>
          </div>
        </section>

        <section class="welcome-section">
          <div class="welcome-section-hdr">
            <h2>Componentes</h2>
            <small>status da migração</small>
          </div>
          <p style="color: var(--gray-700); font-size: 13px; margin: 0 0 12px;">
            Os componentes ainda não foram migrados do <code>wip/</code> para <code>ui_kit/</code>.
            Preview individual será liberado conforme a migração avança — siga o
            <a href="https://github.com/guardiafinance/design-system" target="_blank" rel="noreferrer">ROTEIRO-MIGRACAO.md</a>.
            Enquanto isso, veja os componentes já em produção via
            <a href="/design-system/storybook/" target="_blank" rel="noreferrer">Storybook</a>.
          </p>
        </section>
      </div>
    </main>

    <script is:inline define:vars={{ base }}>
      // ============ CATÁLOGO (port de wip/preview/home.html) ============
      const GROUPS = [
        {
          id: "start", title: "Começar", items: [
            { g: "PP", label: "Primeiros passos",        path: "getting-started.html", key: "primeiros passos comecar comecando getting started instalar setup instalacao npm install primeiro componente" },
          ]
        },
        {
          id: "found", title: "Fundamentos", items: [
            { g: "BR", label: "Branding",                path: "branding.html",   key: "brand branding marca tagline personalidade voz pilares identidade" },
            { g: "PS", label: "Personas",                path: "personas.html",   key: "personas perfis publico audiencia contador empreendedor investidor" },
            { g: "AI", label: "AI-First Experience",     path: "ai-first.html",   key: "ai agentico agente isac conversacao workspace layout padrao diretriz" },
          ]
        },
        {
          id: "color", title: "Cor", items: [
            { g: "01", label: "Paleta base",       path: "colors-base.html",            key: "cor violeta verde vermelho amarelo azul lastro" },
            { g: "02", label: "Escala de cores",   path: "colors-ramps.html",           key: "escala ramp rampas tonalidades 100 300 500 700 900" },
            { g: "03", label: "Mono & Lighthouse", path: "colors-mono-lighthouse.html", key: "mono cinza branco preto lighthouse data viz" },
            { g: "04", label: "Acessibilidade",    path: "colors-accessibility.html",   key: "contraste wcag acessibilidade pareamentos" },
          ]
        },
        {
          id: "type", title: "Tipografia", items: [
            { g: "TF", label: "Famílias",  path: "type-families.html", key: "tipo fontes lastica poppins roboto" },
            { g: "TS", label: "Escala",    path: "type-scale.html",    key: "escala tamanhos display headline body caption" },
          ]
        },
        {
          id: "space", title: "Espaço & forma", items: [
            { g: "TK", label: "Todos os tokens",   path: "tokens.html",                 key: "tokens variaveis variables catalogo completo design tokens css" },
            { g: "SS", label: "Escala de espaço",  path: "spacing-scale.html",         key: "spacing escala 4 8 px grade" },
            { g: "SR", label: "Raios & sombras",   path: "spacing-radii-shadows.html", key: "border-radius radii sombra shadow elevacao" },
          ]
        },
        {
          id: "icon", title: "Iconografia", items: [
            { g: "IK", label: "Visão geral",              path: "iconography.html",              key: "icone iconography lucide stroke overview importar" },
            { g: "AC", label: "Ações essenciais",         path: "iconography-actions.html",      key: "acoes crud save editar excluir busca filtro" },
            { g: "NV", label: "Navegação",                path: "iconography-navigation.html",   key: "navegacao menu chevron arrow layout" },
            { g: "FB", label: "Feedback e estados",       path: "iconography-feedback.html",     key: "feedback status sucesso erro aviso" },
            { g: "GC", label: "Guardia core",             path: "iconography-guardia-core.html", key: "guardia core contabil financeiro fiscal tributario" },
            { g: "AI", label: "Agente IA",                path: "iconography-agent.html",        key: "agente ia bot sparkles ai" },
            { g: "DV", label: "Dados e visualização",     path: "iconography-data.html",         key: "dados grafico chart kpi metric" },
            { g: "FL", label: "Arquivos e documentos",    path: "iconography-files.html",        key: "arquivo documento upload download" },
            { g: "TM", label: "Tempo e agendamento",      path: "iconography-time.html",         key: "tempo calendario prazo agenda" },
            { g: "US", label: "Usuários e acesso",        path: "iconography-users.html",        key: "usuario equipe permissao login" },
            { g: "CO", label: "Comunicação",              path: "iconography-comms.html",        key: "comunicacao notificacao mensagem chat" },
            { g: "SY", label: "Sistema e interface",      path: "iconography-system.html",       key: "sistema integracao api tema" },
          ]
        },
        {
          id: "react", title: "Padrões React", items: [
            { g: "PR", label: "Convenções",   path: "components-react.html", key: "componentes react api padrao convencao cva forwardref" },
          ]
        },
        {
          id: "prim", title: "Primitivos", parent: "comp", items: [
            { g: "AV", label: "Avatar",      desc: "Imagem ou iniciais, 5 tamanhos.", key: "avatar foto iniciais usuario" },
            { g: "BD", label: "Badge",       desc: "Indicador tonal compacto.",        key: "badge selo status tom" },
            { g: "BT", label: "Button",      desc: "Ação principal. 6 variantes.",     key: "botao primario ghost outline cta" },
            { g: "BG", label: "ButtonGroup", desc: "Agrupa ações relacionadas.",       key: "button group barra toolbar" },
            { g: "CH", label: "Chip",        desc: "Token selecionável/removível.",    key: "chip tag filter facet" },
            { g: "IB", label: "IconButton",  desc: "Ação somente com ícone.",          key: "icon button icone" },
            { g: "LB", label: "Label",       desc: "Rótulo de campo.",                 key: "label rotulo required" },
            { g: "SP", label: "Separator",   desc: "Linha divisória.",                 key: "separator divider linha" },
            { g: "SK", label: "Skeleton",    desc: "Placeholder animado.",             key: "skeleton shimmer placeholder" },
            { g: "SN", label: "Spinner",     desc: "Loading inline.",                  key: "spinner loading carregando" },
          ]
        },
        {
          id: "form", title: "Forms", parent: "comp", items: [
            { g: "CK", label: "Checkbox",   desc: "Seleção múltipla.",          key: "checkbox caixa marcar" },
            { g: "CB", label: "Combobox",   desc: "Select com busca.",          key: "combobox autocomplete busca" },
            { g: "DP", label: "DatePicker", desc: "Data ou intervalo.",         key: "date picker calendario data" },
            { g: "FU", label: "FileUpload", desc: "Upload com dropzone.",       key: "upload arquivo dropzone" },
            { g: "FL", label: "FormLayout", desc: "Esqueleto de formulário.",   key: "form layout formulario grid sections fieldset stacked split inline" },
            { g: "IN", label: "Input",      desc: "Campo de texto.",            key: "input campo texto form" },
            { g: "RD", label: "Radio",      desc: "Opção exclusiva.",           key: "radio grupo exclusivo" },
            { g: "SE", label: "Select",     desc: "Dropdown nativo.",           key: "select dropdown nativo" },
            { g: "SL", label: "Slider",     desc: "Faixa contínua.",            key: "slider range faixa" },
            { g: "SW", label: "Switch",     desc: "On/off.",                    key: "switch toggle alternador" },
            { g: "TA", label: "Textarea",   desc: "Campo multi-linha.",         key: "textarea multilinha" },
          ]
        },
        {
          id: "over", title: "Overlays & feedback", parent: "comp", items: [
            { g: "AL", label: "Alert",               desc: "Mensagem inline.",           key: "alert aviso inline" },
            { g: "CI", label: "ConfidenceIndicator", desc: "Alto/Médio/Baixo do agente.", key: "confidence confianca agente" },
            { g: "DG", label: "Dialog",              desc: "Modal bloqueante.",          key: "dialog modal janela" },
            { g: "DR", label: "Drawer",              desc: "Painel lateral.",            key: "drawer painel lateral" },
            { g: "ES", label: "EmptyState",          desc: "Estado vazio com CTAs.",     key: "empty state vazio ilustracao" },
            { g: "MN", label: "Menu",                desc: "Ações contextuais.",         key: "menu context dropdown acoes" },
            { g: "PV", label: "Popover",             desc: "Conteúdo ancorado.",         key: "popover flutuante ancorado" },
            { g: "TS", label: "Toast",               desc: "Notificação transiente.",    key: "toast notificacao snackbar" },
            { g: "TT", label: "Tooltip",             desc: "Dica hover/focus.",          key: "tooltip dica hint" },
          ]
        },
        {
          id: "nav", title: "Navegação", parent: "comp", items: [
            { g: "AC", label: "Accordion",   desc: "Seções expansíveis.",   key: "accordion collapsible colapsavel faq" },
            { g: "BR", label: "Breadcrumbs", desc: "Trilha hierárquica.",   key: "breadcrumbs caminho home" },
            { g: "CM", label: "Command",     desc: "Palette ⌘K.",           key: "command palette cmdk busca global" },
            { g: "PG", label: "Pagination",  desc: "Navegar páginas.",      key: "pagination paginacao" },
            { g: "SB", label: "SidebarNav",  desc: "Navegação lateral.",    key: "sidebar nav menu lateral" },
            { g: "SP", label: "Stepper",     desc: "Progresso em etapas.",  key: "stepper wizard steps etapas onboarding progresso" },
            { g: "TB", label: "Tabs",        desc: "Navegação entre seções.", key: "tabs abas segmented" },
            { g: "TP", label: "TopBar",      desc: "Barra superior.",       key: "topbar header navbar" },
          ]
        },
        {
          id: "data", title: "Dados & conteúdo", parent: "comp", items: [
            { g: "AG", label: "AgentCard",      desc: "Agente com status.",          key: "agent card agente capabilities" },
            { g: "CD", label: "Card",           desc: "Container base.",              key: "card container" },
            { g: "CT", label: "Chart",          desc: "Line/area/bar/donut.",        key: "chart grafico line bar donut" },
            { g: "CA", label: "Calendar",       desc: "Agenda de eventos.",           key: "calendar calendario agenda eventos mes semana fechamento prazo fiscal" },
            { g: "MS", label: "ChatMessage",    desc: "Mensagem do agente/usuário.",  key: "chat message conversa mensagem" },
            { g: "DT", label: "DataTable",      desc: "Tabela com seleção e sort.",   key: "datatable tabela table grid" },
            { g: "KB", label: "Kanban",         desc: "Board com D&D e swimlanes.",   key: "kanban board colunas drag drop swimlanes tarefas" },
            { g: "MC", label: "MetricCard",     desc: "KPI com delta.",               key: "metric kpi metrica delta" },
            { g: "PR", label: "Progress",       desc: "Barra de progresso.",          key: "progress barra" },
            { g: "RC", label: "Reconciliation", desc: "Split fonte A vs B.",          key: "reconciliation conciliar match diff" },
            { g: "TL", label: "Timeline",       desc: "Eventos no tempo.",            key: "timeline linha tempo eventos" },
            { g: "TR", label: "Tree",           desc: "Árvore hierárquica.",          key: "tree arvore hierarquia plano contas categorias aninhado" },
          ]
        },
        {
          id: "brand", title: "Brand", parent: "comp", items: [
            { g: "LG", label: "Logo",     desc: "Símbolo G isolado.",            key: "logo simbolo app icon favicon marca" },
            { g: "LT", label: "Logotipo", desc: "Símbolo + palavra Guardia.",    key: "logotipo wordmark assinatura marca" },
          ]
        },
      ];

      const PARENTS = {
        comp: { title: "Componentes", desc: "pendente de migração do wip" },
      };

      // Registry de componentes já migrados (ui_kit/ no padrão DoD).
      // Adicione o slug (kebab-case) quando a página Astro em /componentes/<slug>
      // estiver publicada — o sidebar passa a apontar pra ela.
      const MIGRATED = new Set([
        "Avatar",
        "Badge",
        "Button",
        "ButtonGroup",
        "Checkbox",
        "Chip",
        "Combobox",
        "DatePicker",
        "FileUpload",
        "FormLayout",
        "IconButton",
        "Input",
        "Label",
        "Radio",
        "Select",
        "Separator",
        "Skeleton",
        "Spinner",
      ]);

      // ============ RENDER NAV ============
      const nav = document.getElementById("nav");
      const navEmpty = document.getElementById("nav-empty");
      const main = document.querySelector("main");
      const welcome = document.getElementById("welcome");

      function render() {
        // Clear (keep navEmpty only)
        nav.innerHTML = "";
        let lastParent = null;
        for (const group of GROUPS) {
          if (group.parent && group.parent !== lastParent) {
            const parentInfo = PARENTS[group.parent];
            if (parentInfo) {
              const phead = document.createElement("div");
              phead.className = "nav-parent";
              phead.dataset.parentId = group.parent;
              phead.innerHTML = `<div class="nav-parent-title"><span>${parentInfo.title}</span></div>`;
              nav.appendChild(phead);
            }
            lastParent = group.parent;
          }
          if (!group.parent) lastParent = null;

          const sect = document.createElement("div");
          sect.className = group.parent ? "nav-group nav-group-sub" : "nav-group";
          sect.dataset.groupId = group.id;
          if (group.parent) sect.dataset.parentOf = group.parent;
          sect.innerHTML = `
            <div class="nav-group-title">
              <span>${group.title}</span>
              <span class="nav-group-count">${group.items.length}</span>
            </div>
          `;
          for (const it of group.items) {
            const a = document.createElement("a");
            a.className = "nav-item";
            a.dataset.id = `${group.id}/${it.label}`;
            a.dataset.search = `${it.label} ${it.key || ""}`.toLowerCase();
            a.dataset.group = group.id;
            const isComponent = ["prim","form","over","nav","data","brand"].includes(group.id);
            if (isComponent) {
              if (MIGRATED.has(it.label)) {
                // slug kebab-case do nome do componente
                const slug = it.label
                  .replace(/([a-z0-9])([A-Z])/g, "$1-$2")
                  .toLowerCase();
                a.dataset.href = `${base}/componentes/${slug}/`;
              } else {
                a.dataset.href = "__pending__";
                a.dataset.componentName = it.label;
              }
            } else {
              a.dataset.href = `${base}/preview/${it.path}`;
            }
            a.innerHTML = `
              <span class="ni-glyph">${it.g}</span>
              <span class="ni-label">${it.label}</span>
            `;
            a.addEventListener("click", (e) => {
              e.preventDefault();
              activate(a);
            });
            sect.appendChild(a);
          }
          nav.appendChild(sect);
        }
        nav.appendChild(navEmpty);
      }

      function activate(el) {
        if (!el) return;
        document.querySelectorAll(".nav-item.active").forEach(n => n.classList.remove("active"));
        el.classList.add("active");
        welcome.style.display = "none";
        main.querySelectorAll("iframe, .stub-pending").forEach(n => n.remove());
        const href = el.dataset.href;
        if (href === "__pending__") {
          const stub = document.createElement("div");
          stub.className = "stub-pending";
          const componentName = el.dataset.componentName;
          stub.innerHTML = `
            <div>
              <h2>${componentName} — em migração</h2>
              <p>
                Este componente ainda está em <code>wip/ui_kits/components/${componentName}/</code>
                e será migrado para <code>ui_kit/</code> seguindo o ROTEIRO-MIGRACAO.md.
              </p>
            </div>
          `;
          main.appendChild(stub);
        } else {
          const iframe = document.createElement("iframe");
          iframe.src = href;
          main.appendChild(iframe);
        }
        const id = el.dataset.id;
        location.hash = encodeURIComponent(id);
        try { localStorage.setItem("guardia-ds-active", id); } catch (e) {}
        el.scrollIntoView({ block: "nearest" });
      }

      function showWelcome() {
        document.querySelectorAll(".nav-item.active").forEach(n => n.classList.remove("active"));
        main.querySelectorAll("iframe, .stub-pending").forEach(n => n.remove());
        welcome.style.display = "";
        location.hash = "";
        try { localStorage.removeItem("guardia-ds-active"); } catch (e) {}
      }

      function activateById(id) {
        if (!id) { showWelcome(); return; }
        const el = document.querySelector(`.nav-item[data-id="${CSS.escape(id)}"]`);
        if (el) activate(el); else showWelcome();
      }

      // Quick-cards
      document.querySelectorAll(".quick-card").forEach(btn => {
        btn.addEventListener("click", () => {
          const go = btn.dataset.go;
          const el = document.querySelector(`.nav-item[data-id="${CSS.escape(go)}"]`);
          if (el) activate(el);
        });
      });

      // ============ SEARCH ============
      const q = document.getElementById("q");
      const qMeta = document.getElementById("q-meta");

      function applyFilter(term) {
        term = (term || "").trim().toLowerCase();
        let matches = 0;
        const groupCounts = new Map();
        document.querySelectorAll(".nav-item").forEach(n => {
          const hit = !term || n.dataset.search.includes(term);
          n.classList.toggle("hide", !hit);
          if (hit) {
            matches++;
            groupCounts.set(n.dataset.group, (groupCounts.get(n.dataset.group) || 0) + 1);
          }
        });
        const parentHasVisible = new Map();
        document.querySelectorAll(".nav-group").forEach(g => {
          const anyVisible = groupCounts.get(g.dataset.groupId) > 0;
          const shouldHide = !!term && !anyVisible;
          g.classList.toggle("hide-all", shouldHide);
          if (!shouldHide && g.dataset.parentOf) {
            parentHasVisible.set(g.dataset.parentOf, true);
          }
        });
        document.querySelectorAll(".nav-parent").forEach(p => {
          const anyVisible = parentHasVisible.get(p.dataset.parentId);
          p.classList.toggle("hide-all", !!term && !anyVisible);
        });
        navEmpty.classList.toggle("visible", !!term && matches === 0);
        qMeta.textContent = term ? `${matches}` : "";
      }

      q.addEventListener("input", () => applyFilter(q.value));
      q.addEventListener("keydown", (e) => {
        if (e.key === "Escape") { q.value = ""; applyFilter(""); q.blur(); }
        if (e.key === "Enter") {
          const firstVisible = document.querySelector(".nav-item:not(.hide)");
          if (firstVisible) activate(firstVisible);
        }
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "/" && document.activeElement !== q) {
          e.preventDefault(); q.focus(); q.select();
        }
      });

      // INIT
      render();
      let initial = null;
      if (location.hash) {
        initial = decodeURIComponent(location.hash.slice(1));
      } else {
        try { initial = localStorage.getItem("guardia-ds-active"); } catch (e) {}
      }
      if (initial) activateById(initial);
      window.addEventListener("hashchange", () => {
        const h = location.hash ? decodeURIComponent(location.hash.slice(1)) : null;
        activateById(h);
      });
    </script>
  </body>
</html>
