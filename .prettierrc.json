{
  "semi": true,
  "singleQuote": false,
  "tabWidth": 4,
  "useTabs": false,
  "trailingComma": "all",
  "printWidth": 100,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "overrides": [
    {
      "files": ["docs/**/*", "*.md", "*.mdx"],
      "options": { "tabWidth": 2 }
    },
    {
      "files": ["*.yml", "*.yaml", "*.json"],
      "options": { "tabWidth": 2 }
    }
  ]
}
