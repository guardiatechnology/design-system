{
  "name": "@guardiafinance/design-system",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles/index.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": [
    "docs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guardiafinance/design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "init:env": "git config core.hooksPath .githooks && chmod -R +x ./.githooks",
    "build": "rslib build",
    "dev": "rslib build --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:dev": "npm run dev --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "dev:all": "concurrently --names \"storybook,docs\" --prefix-colors \"magenta,cyan\" \"npm:storybook\" \"npm:docs:dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "^1.4.2",
    "jotai": "^2.13.1",
    "lucide-react": "^0.542.0",
    "react-day-picker": "^9.13.0",
    "react-hook-form": "^7.62.0",
    "react-select": "^5.10.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "ts-pattern": "^5.9.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.5.11",
    "@rsbuild/plugin-react": "^1.4.0",
    "@rsbuild/plugin-svgr": "^1.2.2",
    "@rslib/core": "^0.14.0",
    "@storybook/addon-essentials": "8.6",
    "@storybook/blocks": "8.6",
    "@storybook/react": "8.6",
    "@storybook/react-vite": "8.6",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "prettier": "^3.4.2",
    "rsbuild-plugin-dts": "^0.14.0",
    "rsbuild-plugin-tailwindcss": "^0.2.3",
    "storybook": "8.6",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.21.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.9.1",
    "zod": "^4.1.8"
  }
}
